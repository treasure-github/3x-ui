[Unit]
Description=x-manager Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/conf.d/x-manager
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/local/x-manager/
ExecStart=/usr/local/x-manager/x-manager
ExecReload=/bin/kill -USR1 $MAINPID
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
